<LauncherScreen>:
    size_hint: 1,1
    pos_hint: {"center_x": 0.5, "center_y": 0.5}

<LauncherLayout>:
    id: launcher_layout
    y: 82
    size_hint_y: 1-(185/Window.height)

<LauncherView>: # Right side of launcher screen
    id: launcher_view
    server_layout: server_layout
    title_layout: title_layout
    module_name: ""
    orientation: 'horizontal'
    padding: dp(50)
    MDBoxLayout:
        orientation: 'vertical'
        spacing: 30
        padding: dp(30)
        theme_bg_color: "Custom"
        md_bg_color: app.theme_cls.surfaceVariantColor
        MDBoxLayout: # Inner padded layout
            orientation: 'vertical'
            MDLabel:
                id: fallback_status_label
                text: root.fallback_status
                size_hint_y: None
                height: dp(40) if self.text else 0
                opacity: 1 if self.text else 0
                halign: 'center'
                theme_font_style: "Custom"
                font_style: "Body"
                role: "medium"
                theme_text_color: "Custom"
                text_color: app.theme_cls.errorColor
            MDBoxLayout: # Title & Favorites
                id: title_layout
                orientation: 'vertical'
                size_hint_y: None
                height: dp(120)
                MDLabel:
                    size_hint_y: 0.37
                    text: app.qotd()
                    halign: 'center'
                    theme_font_style: "Custom"
                    font_style: "Title"
                    role: "small"
                    theme_text_color: "Custom"
                    text_color: app.theme_cls.onSurfaceVariantColor

            MDBoxLayout: # Connect & Play, Patch Game, Create YAML, Generate, Host
                orientation: 'horizontal'
                spacing: 10
                MDBoxLayout:
                    orientation: 'vertical'
                    spacing: dp(15)
                    MDButton:
                        id: connect_button
                        pos_hint: {"center_x": 0.5}
                        on_release: app.launcher_screen.connect()
                        width: dp(200)
                        radius: dp(10)
                        MDButtonText:
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.onSurfaceVariantColor
                            text: 'Connect & Play'
                            halign: 'center'
                        MDButtonIcon:
                            icon: "play-network"
                    MDButton:
                        id: game_patch_button
                        on_release: app.launcher_screen.patch_game()
                        pos_hint: {"center_x": 0.5}
                        width: dp(200)
                        radius: dp(10)
                        MDButtonText:
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.onSurfaceVariantColor
                            text: 'Patch Game'
                            halign: 'center'
                        MDButtonIcon:
                            icon: "file-edit"
                    MDButton:
                        id: game_yaml_button
                        on_release: app.launcher_screen.create_yaml()
                        pos_hint: {"center_x": 0.5}
                        width: dp(200)
                        radius: dp(10)
                        disabled: True
                        MDButtonText:
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.onSurfaceVariantColor
                            text: 'Create YAML'
                            halign: 'center'
                        MDButtonIcon:
                            icon: "code-block-brackets"
                    MDButton:
                        id: generate_button
                        on_release: app.launcher_screen.generate()
                        pos_hint: {"center_x": 0.5}
                        width: dp(200)
                        radius: dp(10)
                        MDButtonText:
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.onSurfaceVariantColor
                            text: 'Generate'
                            halign: 'center'
                        MDButtonIcon:
                            icon: "gamepad-square-outline"
                    MDButton:
                        id: host_button
                        on_release: app.launcher_screen.host()
                        pos_hint: {"center_x": 0.5}
                        width: dp(200)
                        radius: dp(10)
                        MDButtonText:
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.onSurfaceVariantColor
                            text: 'Host'
                            halign: 'center'
                        MDButtonIcon:
                            icon: "router-network"
                MDBoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    width: dp(10)
                    size_hint_x: None
                    MDDivider:
                        size_hint_y: .8
                        pos_hint: {"center_y": 0.5}
                        orientation: "vertical"
                        color: app.theme_cls.outlineColor
                MDBoxLayout:
                    id: server_layout
                    orientation: 'vertical'
                    spacing: dp(15)
                    LauncherAuthTextField:
                        id: server
                        size_hint_x: 0.8
                        pos_hint: {"center_x": 0.5}
                        text: app.ctx.hostname
                        MDTextFieldLeadingIcon:
                            theme_icon_color: "Custom"
                            icon: 'router-network'
                            icon_color_focus: self.parent.icon_color_focus
                            icon_color_normal: self.parent.icon_color_normal
                        MDTextFieldHintText:
                            text: "Server Address"
                    LauncherAuthTextField:
                        id: port
                        input_filter: 'int'
                        size_hint_x: 0.8
                        pos_hint: {"center_x": 0.5}
                        text: app.ctx.port
                        MDTextFieldLeadingIcon:
                            theme_icon_color: "Custom"
                            icon: 'numeric'
                            icon_color_focus: self.parent.icon_color_focus
                            icon_color_normal: self.parent.icon_color_normal
                        MDTextFieldHintText:
                            text: "Port"
                    LauncherAuthTextField:
                        id: slot_name
                        size_hint_x: 0.8
                        pos_hint: {"center_x": 0.5}
                        text: app.ctx.username
                        on_text_validate: app.launcher_screen.connect()
                        MDTextFieldLeadingIcon:
                            theme_icon_color: "Custom"
                            icon_color_focus: self.parent.icon_color_focus
                            icon_color_normal: self.parent.icon_color_normal
                            icon: 'ticket-account'
                        MDTextFieldHintText:
                            text: "Username"
                    LauncherAuthTextField:
                        id: slot_password
                        password: True
                        size_hint_x: 0.8
                        pos_hint: {"center_x": 0.5}
                        text: app.app_config.get("client", "slot_password", fallback="")
                        on_text_validate: app.launcher_screen.connect()
                        MDTextFieldLeadingIcon:
                            theme_icon_color: "Custom"
                            icon_color_focus: self.parent.icon_color_focus
                            icon_color_normal: self.parent.icon_color_normal
                            icon: 'lock'    
                        MDTextFieldHintText:
                            text: "Password"

<LauncherGenerateContent>:
    orientation: 'vertical'
    spacing: dp(15)
    adaptive_height: True
    LauncherAuthTextField:
        id: seed
        size_hint_x: 0.8
        pos_hint: {"center_x": 0.5}
        MDTextFieldHintText:
            text: "Seed"
        MDTextFieldLeadingIcon:
            theme_icon_color: "Custom"
            icon_color_focus: self.parent.icon_color_focus
            icon_color_normal: self.parent.icon_color_normal
            icon: 'seed'
    LauncherAuthTextField:
        id: output
        size_hint_x: 0.8
        pos_hint: {"center_x": 0.5}
        MDTextFieldHintText:
            text: "Output Directory"
        MDTextFieldLeadingIcon:
            theme_icon_color: "Custom"
            icon_color_focus: self.parent.icon_color_focus
            icon_color_normal: self.parent.icon_color_normal
            icon: 'folder'

<LauncherHostContent>:
    orientation: 'vertical'
    spacing: dp(15)
    adaptive_height: True
    LauncherAuthTextField:
        id: port
        input_filter: 'int'
        size_hint_x: 0.8
        pos_hint: {"center_x": 0.5}
        MDTextFieldHintText:
            text: "Port (default: 38281)"
        MDTextFieldLeadingIcon:
            theme_icon_color: "Custom"
            icon_color_focus: self.parent.icon_color_focus
            icon_color_normal: self.parent.icon_color_normal
            icon: 'numeric'
    LauncherAuthTextField:
        id: admin_password
        password: True
        size_hint_x: 0.8
        pos_hint: {"center_x": 0.5}
        MDTextFieldHintText:
            text: "Remote Admin Password (optional)"
        MDTextFieldLeadingIcon:
            theme_icon_color: "Custom"
            icon_color_focus: self.parent.icon_color_focus
            icon_color_normal: self.parent.icon_color_normal
            icon: 'lock'

<LauncherPatchContent>:
    orientation: 'vertical'
    spacing: dp(15)
    adaptive_height: True
    LauncherAuthTextField:
        id: output
        size_hint_x: 0.8
        pos_hint: {"center_x": 0.5}
        MDTextFieldHintText:
            text: "Output Directory (optional)"
        MDTextFieldLeadingIcon:
            theme_icon_color: "Custom"
            icon_color_focus: self.parent.icon_color_focus
            icon_color_normal: self.parent.icon_color_normal
            icon: 'folder'

<TagChip>:
    type: "filter"
    MDChipText:
        text: root.text
        icon: root.icon

<LauncherAuthTextField>:
    theme_font_name: "Custom"
    theme_font_style: "Custom"
    theme_icon_color: "Custom"
    theme_text_color: "Custom"
    theme_bg_color: "Custom"
    text_color_focus: app.theme_cls.onSecondaryContainerColor
    text_color_normal: app.theme_cls.onSurfaceVariantColor
    icon_color_focus: app.theme_cls.primaryColor
    icon_color_normal: app.theme_cls.onPrimaryColor
    fill_color_focus: app.theme_cls.surfaceContainerHighestColor
    fill_color_normal: app.theme_cls.surfaceVariantColor
    font_name: app.theme_cls.font_styles[self.font_style][self.role]["font-name"]
    font_size: app.theme_cls.font_styles[self.font_style][self.role]["font-size"]
    mode: "filled"
    write_tab: False