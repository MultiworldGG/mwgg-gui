<GameListPanel>:
    padding: dp(8),dp(4),dp(8),dp(4)
    id: game_item
    MDExpansionPanelHeader:
        padding: dp(8),0,dp(8),0
        radius: dp(8),0,dp(8),0
        id: panel_header
    MDExpansionPanelContent:
        id: panel_content
        orientation: 'vertical'
        y: 82
        padding: dp(12), 0, dp(12), dp(12)
        spacing: dp(8)
        MDLabel:
            adaptive_height: True
            padding: 0

<SlotListItemHeader>:
    id: slot_item_header
    spacing: dp(4)
    padding: dp(8),dp(4),dp(8),dp(4)
    orientation: "horizontal"
    height: dp(70)
    size_hint_y: None
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.secondaryContainerColor
    theme_shadow_color: "Custom"
    shadow_color: app.theme_cls.shadowColor
    theme_elevation_level: "Custom"
    elevation_level: 0
    search: False
    waiting: False
    MDListItemLeadingAvatar:
        width: dp(40)
        id: leading_avatar
        source: root.item_data['avatar']
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: 1
        padding: 0,dp(10),0,dp(10)
        MDBoxLayout:
            id: slot_item_container
            orientation: "horizontal"
            size_hint_y: .5
            MDListItemHeadlineText:
                id: slot_item_name
                shorten: False
                do_wrap: True
                text: root.slot_name
                theme_text_color: "Custom"
                text_color: app.theme_cls.onSecondaryContainerColor
                pos_hint: {"center_y": 0.5}
        MDBoxLayout:
            id: game_item_container
            orientation: "horizontal"
            size_hint_y: .5
            MDListItemTertiaryText:
                id: slot_item_game
                shorten: False
                do_wrap: True
                text: root.item_data['game']
                theme_text_color: "Custom"
                pos_hint: {"center_y": 0.5}
                text_color: app.theme_cls.onSecondaryContainerColor
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)

<HintListItemHeader>:
    id: hint_item_header
    padding: dp(8),0,dp(8),0
    radius: dp(8)
    variable_height: True
    orientation: "horizontal"
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.secondaryContainerColor
    MDListItemLeadingIcon:
        icon: root.hint_icon
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDListItemHeadlineText:
        id: hint_item_header_text
        text: root.hint_text
        text_color: app.theme_cls.onSurfaceColor
        theme_text_color: "Custom"
        shorten: False
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)

<GameListItemHeader>:
    id: game_item_header
    spacing: dp(4)
    padding: dp(8),dp(4),dp(8),dp(4)
    height: dp(60)
    size_hint_y: None
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.tertiaryContainerColor if self.state == "down" else app.theme_cls.secondaryContainerColor
    on_release: root.on_release(self, args)
    MDListItemLeadingAvatar:
        id: leading_avatar
        source: root.game_data['cover_url']
        width: dp(40)
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDListItemSupportingText:
        id: game_item_header_text
        text: root.game_data["game_name"]
        text_color: app.theme_cls.onSurfaceColor
        theme_text_color: "Custom"
        role: "medium"
        shorten: False
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)

<ListItemTooltip>:
    MDTooltipPlain:
        text: root.tooltip_text
        do_wrap: True
        adaptive_height: True
        theme_text_color: "Custom"
        theme_bg_color: "Custom"
        md_bg_color: app.theme_cls.secondaryContainerColor
        text_color: app.theme_cls.onSecondaryContainerColor

<GameListItem>:
    tooltip_text: ""
    ripple_effect: False
    theme_elevation_level: "Custom"
    MDListItemLeadingIcon:
        icon: root.icon

<GameListItemLongText>:
    text: root.text
    size_hint_x: 1
    tooltip_text: root.tooltip_text
    shorten: False
    do_wrap: False
    adaptive_height: True
    role: "small"

<GameListItemShortText>:
    text: root.text
    size_hint_x: 1
    shorten: False
    do_wrap: False
    adaptive_height: True
    role: "small"    

<HintListItemLabel>:
    tooltip_text: self.text
    size_hint_x: 1
    shorten: False
    do_wrap: True
    adaptive_height: True

<MWBaseListItem>:
    spacing: dp(8)
    padding: 12, 12, 12, 12
    orientation: "vertical"
    ripple_effect: False
    theme_shadow_color: "Custom"
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceContainerColor
    theme_elevation_level: "Custom"

<SlotListItem>:
    id: slot_item
    entrance_texture: (0, 0)
    height: dp(70) # Default height because AAAAAAA
    my_item: False
    size_hint_y: None
    MDBoxLayout:
        id: slot_item_top_container
        orientation: "horizontal"
        spacing: dp(4)
        adaptive_height: True
        valign: "center"
        pos_hint: {"center_y": 0.5}
        MDListItemLeadingIcon:
            id: slot_icon_location
            icon: "sign-direction"
            pos_hint: {"center_y": 0.55}
        MDListItemSupportingText:
            id: slot_text_location
            text: root.location_name
            pos_hint: {"center_y": 0.5}
            shorten: False
            do_wrap: True
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
    MDBoxLayout:
        id: slot_item_bottom_container
        orientation: "horizontal"
        spacing: dp(4)
        adaptive_height: True
        valign: "center"
        pos_hint: {"center_y": 0.5}
        MDListItemLeadingIcon:
            id: slot_icon_item
            icon: "treasure-chest"
            pos_hint: {"center_y": 0.55}
        MDListItemSupportingText:
            id: slot_text_item
            text: root.item_name
            pos_hint: {"center_y": 0.5}
            do_wrap: True
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
        MDListItemTrailingIcon:
            id: slot_icon_goal
            icon: "flag_checkered"
            pos_hint: {"center_y": 0.5}

<HintListItem>:
    id: hint_item
    height: dp(72)
    size_hint_y: None
    spacing: dp(4)
    editable: False
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceContainerColor
    MDBoxLayout:
        sort_key: 'player_name'
        spacing: dp(4)
        padding: dp(4), 0, dp(4), 0
        size_hint_x: None
        width: dp(180)
        MDBoxLayout:
            width: dp(25)
            size_hint_x: None
            height: dp(25)
            size_hint_y: None
            radius: dp(20)
            pos_hint: {"x": 0,"center_y": 0.5}
            FitImage:
                source: root.player_avatar
                radius: dp(20)
                fit_mode: 'contain'
        MDLabel:
            id: player
            text: root.player_name
            size_hint_x: 1
            pos_hint: {"x": 0, "center_y": 0.5}
    MDBoxLayout:
        sort_key: 'item_name'
        spacing: dp(4)
        MDIcon:
            width: dp(20)
            size_hint_x: None
            id: slot_icon_item
            icon: "treasure-chest"
            pos_hint: {"x": 0, "center_y": 0.5}
            IconBadge:
                id: slot_icon_item_badge
                text: root.item_badge_text
                opacity: 0 if not root.item_badge_text else 1
        HintListItemLabel:
            id: slot_text_item
            text: root.item_name
            size_hint_x: 1
            pos_hint: { "x": 0, "center_y": 0.5}
    MDBoxLayout:
        sort_key: 'location_name'
        spacing: dp(4)
        MDIcon:
            width: dp(20)
            size_hint_x: None
            id: slot_icon_location
            icon: "sign-direction"
            pos_hint: {"x": 0, "center_y": 0.5}
            IconBadge:
                id: slot_icon_location_badge
                text: root.location_badge_text
                opacity: 0 if not root.location_badge_text else 1
        HintListItemLabel:
            id: slot_text_location
            text: root.location_name
            size_hint_x: 1
            pos_hint: { "x": 0, "center_y": 0.5}
    MDBoxLayout:
        sort_key: 'entrance_name'
        spacing: dp(4)
        width: dp(100)
        size_hint_x: None
        MDIcon:
            id: slot_icon_entrance
            width: dp(20)
            size_hint_x: None
            icon: "door-open"
            pos_hint: {"center_y": 0.5}
        HintListItemLabel:
            id: slot_text_entrance
            text: root.entrance_name
            size_hint_x: 1
            pos_hint: { "x": 0, "center_y": 0.5}
    MDBoxLayout:
        size_hint_x: None
        width: dp(130)
        padding: dp(6), 0, dp(6), 0
        pos_hint: { "x": 0, "center_y": 0.5}
        MDRelativeLayout:
            id: slot_status
            spacing: dp(4)
            MDButton:
                width: dp(100)
                size_hint_x: None
                pos_hint: { "x": 0, "center_y": 0.5}
                id: hint_item_status_button
                opacity: 1 if root.editable else 0
                disabled: not root.editable
                on_release: root.open_dropdown()
                MDButtonIcon:
                    icon: root.hint_icon_status
                MDButtonText:
                    text: root.hint_status_text
            MDBoxLayout:
                id: hint_item_status_container
                halign: 'center'
                valign: 'center'
                pos_hint: {"center_y": 0.5}
                opacity: 0 if root.editable else 1
                MDIcon:
                    width: dp(25)
                    size_hint_x: None
                    pos_hint: {"x": 0, "center_y": 0.5}
                    icon: root.hint_icon_status
                MDLabel:
                    text: root.hint_status_text
                    size_hint_x: 1
                    pos_hint: {"center_y": 0.5}
    MDBoxLayout:
        size_hint_x: None
        width: dp(100)
        padding: dp(6), 0, 0, 0
        pos_hint: { "x": 0, "center_y": 0.5}
        MDRelativeLayout:
            id: slot_mwgg_status
            MDBoxLayout:
                id: slot_mwgg_status_checkbox_container
                pos_hint: { "x": 0, "center_y": 0.5}
                spacing: dp(4)
                opacity: 1 if root.editable else 0
                MDCheckbox:
                    id: slot_mwgg_status_checkbox_bk
                    width: dp(24)
                    size_hint_x: None
                    checkbox_icon_normal: "food-off"
                    checkbox_icon_down: "food"
                    color_active: app.theme_cls.errorColor
                    color_normal: app.theme_cls.disabledTextColor
                    on_active: root.set_bkmode(root, self.active)
                    pos_hint: {"center_y": 0.5}
                MDCheckbox:
                    id: slot_mwgg_status_checkbox_goal
                    width: dp(24)
                    size_hint_x: None
                    checkbox_icon_normal: "flag_checkered"
                    checkbox_icon_down: "flag_checkered"
                    color_active: app.theme_cls.onBackgroundColor
                    color_normal: app.theme_cls.disabledTextColor
                    on_active: root.set_goal(root, self.active)
                    pos_hint: {"center_y": 0.5}
                MDCheckbox:
                    id: slot_mwgg_status_checkbox_shop
                    width: dp(24)
                    size_hint_x: None
                    checkbox_icon_normal: "shop"
                    checkbox_icon_down: "shopping"
                    color_active: app.theme_cls.tertiaryColor
                    color_normal: app.theme_cls.disabledTextColor
                    on_active: root.set_shop(root, self.active)
                    pos_hint: {"center_y": 0.5}
            MDBoxLayout:
                id: slot_mwgg_status_icon_container
                size_hint_x: None
                spacing: dp(4)
                pos_hint: { "x": 0, "center_y": 0.5}
                width: self.minimum_width
                opacity: 1 if not root.editable else 0
                MDIcon:
                    id: slot_mwgg_status_icon_bk
                    sort_key: 'for_bk_mode'
                    width: dp(25)
                    size_hint_x: None
                    icon: "blank"
                    pos_hint: {"center_y": 0.5}
                MDIcon:
                    id: slot_mwgg_status_icon_goal
                    sort_key: 'for_goal'
                    width: dp(25)
                    size_hint_x: None
                    icon: "blank"
                    pos_hint: {"center_y": 0.5}
                MDIcon:
                    id: slot_mwgg_status_icon_shop
                    sort_key: 'from_shop'
                    width: dp(25)
                    size_hint_x: None
                    icon: "blank"
                    pos_hint: {"center_y": 0.5}
    MDBoxLayout:
        id: hide
        width: dp(32)
        size_hint_x: None
        halign: 'center'
        valign: 'center'
        pos_hint: {"center_y": 0.5}
        MDCheckbox:
            id: hide_checkbox
            width: dp(25)
            size_hint_x: None
            pos_hint: {"center_y": 0.5}
            on_active: root.on_hide(root, self.active)
            color_active: app.theme_cls.disabledTextColor
            color_normal: app.theme_cls.primaryColor
            checkbox_icon_down: "eye-off"
            checkbox_icon_normal: "eye"

<IconBadge>:
    text: ""
    theme_font_style: "Custom"
    role: "large"
    font_style: "Icon"
    theme_font_size: "Custom"
    font_size: dp(11)
